# ============================================
# SUPABASE CONFIGURATION - EXAMPLE FILE
# Copie este arquivo para .env e preencha com seus valores reais
# ============================================

# URL do projeto Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima (pública) - usada no client-side
SUPABASE_ANON_KEY=sua-chave-anon-aqui
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Chave secreta (nunca exponha no client-side!)
SUPABASE_SECRET_KEY=sua-chave-secreta-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Publishable keys
SUPABASE_PUBLISHABLE_KEY=sua-publishable-key-aqui
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua-publishable-key-aqui

# JWT Secret
SUPABASE_JWT_SECRET=seu-jwt-secret-aqui

# ============================================
# POSTGRES DATABASE CONFIGURATION
# ============================================

POSTGRES_HOST=db.seu-projeto.supabase.co
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua-senha-aqui
POSTGRES_DATABASE=postgres

# Connection URLs
POSTGRES_PRISMA_URL=postgres://postgres.seu-projeto:sua-senha@host:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_URL=postgres://postgres.seu-projeto:sua-senha@host:6543/postgres?sslmode=require
POSTGRES_URL_NON_POOLING=postgres://postgres.seu-projeto:sua-senha@host:5432/postgres?sslmode=require

# ============================================
# INSTRUÇÕES
# ============================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha com valores reais do seu projeto Supabase
# 3. NUNCA commit o arquivo .env (já está no .gitignore)
# 4. As chaves NEXT_PUBLIC_* são seguras para client-side
# 5. SUPABASE_SERVICE_ROLE_KEY e SUPABASE_SECRET_KEY são sensíveis!
# ============================================
